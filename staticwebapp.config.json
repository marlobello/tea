{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/css/*", "/js/*", "/assets/*", "*.{csv,png,ico,svg,json}"]
  },
  "mimeTypes": {
    ".csv": "text/csv",
    ".js": "text/javascript"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "no-referrer",
    "X-Frame-Options": "DENY"
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  }
}
